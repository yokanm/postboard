{
  "name": "job-board-api",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json && tsc-alias",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.ts --forceExit",
    "test:ci": "jest --ci --coverage --forceExit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "db:seed": "tsx -r tsconfig-paths/register src/seeds/index.ts",
    "db:seed:super": "tsx -r tsconfig-paths/register src/seeds/superadmin.ts",
    "db:reset": "npx prisma migrate reset --force && npm run db:seed",
    "test:load": "node tests/load/benchmark.mjs",
    "worker:dev": "tsx watch -r tsconfig-paths/register src/workers/email.worker.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@logtail/node": "^0.5.8",
    "@logtail/winston": "^0.5.8",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.74.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsdom": "^29.0.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.9.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",

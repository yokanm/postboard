# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── App URLs ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000

# ─── JWT — Generate with: openssl rand -hex 64 ──────────────
JWT_ACCESS_SECRET=replace-with-generated-secret
JWT_REFRESH_SECRET=replace-with-different-generated-secret
JWT_SUPERADMIN_SECRET=replace-with-another-generated-secret
JWT_SUPERADMIN_REFRESH_SECRET=replace-with-yet-another-generated-secret
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d

ENABLE_BULL_BOARD=false
ENABLE_DOCS=false

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_replace-with-your-resend-api-key
EMAIL_FROM=onboarding@resend.dev

# ─── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=replace-with-your-cloud-name
CLOUDINARY_API_KEY=replace-with-your-api-key
CLOUDINARY_API_SECRET=replace-with-your-api-secret

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:replace-password@localhost:5432/jobboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=jobboard
POSTGRES_HOST_PORT=5432

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Super Admin ────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=replace-with-strong-password
SUPER_ADMIN_FIRST_NAME=Admin
SUPER_ADMIN_LAST_NAME=User
